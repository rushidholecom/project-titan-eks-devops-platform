pipeline{
    agent any
    stages{
        stage('pull'){
            steps{
                git branch: 'main', url: 'https://github.com/rushidholecom/project-titan-eks-devops-platform.git'
            }
        }

        stage('Run'){
            steps{
                timeout(time: 15, unit: 'MINUTES'){
                    sh '''cd terraform
                          terraform init
                          terraform plan'''
                }
            }
        }

        stage('APPOVAL'){
            steps{
                input 'wait for approval'
            }
        }

        stage('DEPLOY'){
            steps{
                timeout(time: 15, unit: 'MINUTES'){
                    sh '''cd terraform
                          terraform apply --auto-approve
                          '''
                }
            }
        }

        stage('APPOVAL'){
            steps{
                input 'wait for approval'
            }
        }

        stage('DESTROY'){
            steps{
                sh '''cd terraform
                      terraform destroy -auto-approve'''    
            }
        }
        
    }
}